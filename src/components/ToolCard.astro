---
import { formatNumber, type ToolWithCategories } from "@/lib/directory";
import { localizedPath, t, type Lang } from "@/lib/i18n";

type Props = {
  tool: ToolWithCategories;
  lang: Lang;
};

const { tool, lang } = Astro.props;
---

<article class="tool-card">
  <div class="tool-card-head">
    <span class="tool-logo">{tool.logo}</span>
    <div>
      <h3><a href={localizedPath(lang, `/tools/${tool.slug}`)}>{tool.name[lang]}</a></h3>
      <div class="meta-row">
        <span class="pill">{tool.pricing}</span>
        {tool.featured && <span class="pill featured">Featured</span>}
      </div>
    </div>
  </div>
  <p>{tool.tagline[lang]}</p>
  <div class="tag-row">
    {
      tool.categoryItems.map((category) => (
        <a class="pill" href={localizedPath(lang, `/categories/${category.slug}`)}>
          {category.name[lang]}
        </a>
      ))
    }
  </div>
  <div class="meta-row">
    <span class="pill">{formatNumber(tool.monthlyVisits, lang)} {t(lang, "visits")}</span>
    <span class="pill">{formatNumber(tool.savedCount, lang)} {t(lang, "saves")}</span>
  </div>
</article>
