---
import "@/styles/global.css";
import { languages, localizedPath, t, type Lang } from "@/lib/i18n";

type Props = {
  lang: Lang;
  title: string;
  description: string;
};

const { lang, title, description } = Astro.props;
const navItems = [
  { href: localizedPath(lang, "/accounts"), label: t(lang, "navAccounts") },
  { href: localizedPath(lang, "/platforms"), label: t(lang, "navPlatforms") },
  { href: localizedPath(lang, "/categories"), label: t(lang, "navCategories") },
  { href: localizedPath(lang, "/rankings"), label: t(lang, "navRankings") },
  { href: localizedPath(lang, "/new"), label: t(lang, "navNew") },
  { href: localizedPath(lang, "/services"), label: t(lang, "navServices") },
  { href: localizedPath(lang, "/submit"), label: t(lang, "navSubmit") },
  { href: "https://d.limingdao.com/", label: t(lang, "navTransfer"), external: true },
  { href: "https://cms.limingdao.com/", label: t(lang, "navDirectory"), external: true }
];

const currentPath = Astro.url.pathname.replace(/^\/(en|zh)/, "") || "/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="sponsor-strip">
      <div class="container sponsor-strip-inner">
        <span>🔥 {t(lang, "slogan")}</span>
        <a href={localizedPath(lang, "/services")} class="banner-cta-link">
          {lang === "zh" ? "了解 AI 代运营服务 →" : "Learn AI Management Services →"}
        </a>
      </div>
    </div>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href={localizedPath(lang, "/")} aria-label={t(lang, "brand")}>
          <span class="brand-mark">🌅</span>
          <span>{t(lang, "brand")}</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {navItems.map((item) => (
            <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}>
              {item.label}
            </a>
          ))}
          <span class="lang-switch" aria-label="Language">
            {
              languages.map((item) => (
                <a href={localizedPath(item, currentPath)} aria-current={item === lang ? "true" : "false"}>
                  {item.toUpperCase()}
                </a>
              ))
            }
          </span>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-content">
        <div class="footer-brand">
          <strong>🌅 {t(lang, "brand")}</strong>
          <p>{t(lang, "footerTagline")}</p>
        </div>
        <div class="footer-links">
          <a href={localizedPath(lang, "/services")}>{t(lang, "navServices")}</a>
          <a href={localizedPath(lang, "/submit")}>{t(lang, "navSubmit")}</a>
          <a href={localizedPath(lang, "/contact")}>{t(lang, "contactTitle")}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
