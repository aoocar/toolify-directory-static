---
import CategoryCard from "@/components/CategoryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategories } from "@/lib/directory";
import { languages, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const categories = await getCategories();
---

<BaseLayout lang={lang} title={`${t(lang, "categories")} - ${t(lang, "brand")}`} description={t(lang, "heroSubtitle")}>
  <section class="page-title">
    <div class="container">
      <h1>{t(lang, "categories")}</h1>
      <p class="lead">{t(lang, "heroSubtitle")}</p>
    </div>
  </section>
  <section class="section">
    <div class="container category-grid">
      {categories.map((category) => <CategoryCard category={category} lang={lang} />)}
    </div>
  </section>
</BaseLayout>
