---
import CategoryCard from "@/components/CategoryCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategories, getCategoryCounts } from "@/lib/directory";
import { languages, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const categories = await getCategories();
const categoryCounts = await getCategoryCounts();
---

<BaseLayout lang={lang} title={`${t(lang, "navCategories")} - ${t(lang, "brand")}`} description={t(lang, "heroSubtitle")}>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h1>{t(lang, "navCategories")}</h1>
      </div>
      <div class="category-grid">
        {
          categories.map((category) => {
            const count = categoryCounts.find((c) => c.category.slug === category.slug)?.count || 0;
            return <CategoryCard category={category} lang={lang} count={count} />;
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
