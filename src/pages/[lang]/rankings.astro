---
import AccountCard from "@/components/AccountCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getRankedAccounts } from "@/lib/directory";
import { languages, localizedPath, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const url = Astro.url;
const tab = url.searchParams.get("tab") || "followers";

let activeTab: "followers" | "engagement" | "growth" = "followers";
if (tab === "engagement" || tab === "growth") {
  activeTab = tab;
}

const rankedAccounts = await getRankedAccounts(activeTab);
---

<BaseLayout lang={lang} title={`${t(lang, "navRankings")} - ${t(lang, "brand")}`} description={t(lang, "heroSubtitle")}>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h1>{t(lang, "navRankings")}</h1>
        <div class="tab-row" role="tablist">
          <a
            class={`tab-button ${activeTab === "followers" ? "active" : ""}`}
            href={`${localizedPath(lang, "/rankings")}?tab=followers`}
            role="tab"
          >
            {t(lang, "rankByFollowers")}
          </a>
          <a
            class={`tab-button ${activeTab === "engagement" ? "active" : ""}`}
            href={`${localizedPath(lang, "/rankings")}?tab=engagement`}
            role="tab"
          >
            {t(lang, "rankByEngagement")}
          </a>
          <a
            class={`tab-button ${activeTab === "growth" ? "active" : ""}`}
            href={`${localizedPath(lang, "/rankings")}?tab=growth`}
            role="tab"
          >
            {t(lang, "rankByGrowth")}
          </a>
        </div>
      </div>

      <div class="grid">
        {rankedAccounts.map((account) => <AccountCard account={account} lang={lang} />)}
      </div>
    </div>
  </section>
</BaseLayout>
