---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { languages, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<BaseLayout lang={lang} title={`${t(lang, "submitTitle")} - ${t(lang, "brand")}`} description={t(lang, "submitBody")}>
  <section class="section">
    <div class="container narrow-container">
      <div class="section-head text-center">
        <h1>{t(lang, "submitTitle")}</h1>
        <p class="lead">{t(lang, "submitBody")}</p>
      </div>

      <form class="submit-form" id="submit-form">
        <div class="form-group">
          <label for="creator-name">{lang === "zh" ? "账号名称" : "Creator Name"}</label>
          <input type="text" id="creator-name" required placeholder={lang === "zh" ? "例：灵感画手艾米" : "e.g. ArtifyVision"} />
        </div>
        <div class="form-group">
          <label for="creator-url">{lang === "zh" ? "账号链接" : "Account URL"}</label>
          <input type="url" id="creator-url" required placeholder="https://..." />
        </div>
        <div class="form-group">
          <label for="creator-platform">{lang === "zh" ? "所在平台" : "Platform"}</label>
          <input type="text" id="creator-platform" required placeholder={lang === "zh" ? "例：小红书、抖音、YouTube" : "e.g. Xiaohongshu, Douyin"} />
        </div>
        <div class="form-group">
          <label for="creator-reason">{lang === "zh" ? "推荐理由" : "Why recommend this creator"}</label>
          <textarea id="creator-reason" rows="4" placeholder={lang === "zh" ? "请简述该账号的内容特色与核心价值..." : "Briefly describe their content style and value..."}></textarea>
        </div>
        <button class="button primary full-width" type="submit">
          {lang === "zh" ? "提交审核" : "Submit"}
        </button>
        <p class="submit-hint">
          {lang === "zh"
            ? "提交后会打开你的邮件客户端，内容将发送至 aoobee@sina.com。如需接入服务端接口，可改为 hybrid rendering + API。"
            : "Submitting opens your mail client and sends to aoobee@sina.com. For a server endpoint, switch to hybrid rendering + API."}
        </p>
      </form>

      <script>
        const form = document.getElementById("submit-form");
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          const name = document.getElementById("creator-name").value.trim();
          const url = document.getElementById("creator-url").value.trim();
          const platform = document.getElementById("creator-platform").value.trim();
          const reason = document.getElementById("creator-reason").value.trim();
          const subject = encodeURIComponent("创作者推荐：" + name);
          const body = encodeURIComponent(
            "账号名称：" + name + "\n账号链接：" + url + "\n所在平台：" + platform + "\n推荐理由：" + reason
          );
          window.location.href = "mailto:aoobee@sina.com?subject=" + subject + "&body=" + body;
        });
      </script>
    </div>
  </section>
</BaseLayout>
