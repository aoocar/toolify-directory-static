---
import AccountCard from "@/components/AccountCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAccountsByPlatform, getPlatformBySlug } from "@/lib/directory";
import { languages, localizedPath, t, type Lang } from "@/lib/i18n";

export async function getStaticPaths() {
  const platforms = [
    "douyin",
    "xiaohongshu",
    "bilibili",
    "youtube",
    "weibo",
    "twitter-x",
    "instagram",
    "tiktok",
    "kuaishou",
    "zhihu"
  ];
  const paths = [];

  for (const lang of languages) {
    for (const plat of platforms) {
      paths.push({ params: { lang, slug: plat } });
    }
  }

  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const platform = await getPlatformBySlug(slug);

if (!platform) {
  return Astro.redirect(localizedPath(lang, "/404"));
}

const platformAccounts = await getAccountsByPlatform(slug);
---

<BaseLayout lang={lang} title={`${platform.name[lang]} - ${t(lang, "brand")}`} description={platform.description[lang]}>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h1>{platform.icon} {platform.name[lang]}</h1>
        <p class="lead">{platform.description[lang]}</p>
      </div>

      {
        platformAccounts.length > 0 ? (
          <div class="grid">
            {platformAccounts.map((account) => <AccountCard account={account} lang={lang} />)}
          </div>
        ) : (
          <div class="empty-state">
            <p>{t(lang, "empty")}</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
