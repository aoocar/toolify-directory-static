---
import CategoryCard from "@/components/CategoryCard.astro";
import ToolCard from "@/components/ToolCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategories, getFeaturedTools, getLatestTools, getRankedTools } from "@/lib/directory";
import { languages, localizedPath, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const [featuredTools, latestTools, rankedTools, categories] = await Promise.all([
  getFeaturedTools(),
  getLatestTools(3),
  getRankedTools(3),
  getCategories()
]);
---

<BaseLayout lang={lang} title={`${t(lang, "brand")} - ${t(lang, "heroTitle")}`} description={t(lang, "heroSubtitle")}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{t(lang, "allTools")}</p>
        <h1>{t(lang, "heroTitle")}</h1>
        <p class="lead">{t(lang, "heroSubtitle")}</p>
        <form class="search-panel" action={localizedPath(lang, "/tools")} method="get">
          <input name="q" type="search" placeholder={t(lang, "searchPlaceholder")} />
          <button class="button" type="submit">{t(lang, "search")}</button>
        </form>
      </div>
      <aside class="stats-card" aria-label="Directory stats">
        <div class="stat">
          <strong>6</strong>
          <span>{t(lang, "seedTools")}</span>
        </div>
        <div class="stat">
          <strong>6</strong>
          <span>Categories</span>
        </div>
        <div class="stat">
          <strong>2</strong>
          <span>{t(lang, "languagesReady")}</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "featured")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/tools")}>{t(lang, "allTools")}</a>
      </div>
      <div class="grid">
        {featuredTools.map((tool) => <ToolCard tool={tool} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "categories")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/categories")}>{t(lang, "navCategories")}</a>
      </div>
      <div class="category-grid">
        {categories.map((category) => <CategoryCard category={category} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "latest")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/new")}>{t(lang, "navNew")}</a>
      </div>
      <div class="grid">
        {latestTools.map((tool) => <ToolCard tool={tool} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "rankings")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/rankings")}>{t(lang, "navRankings")}</a>
      </div>
      <div class="ranking-list">
        {
          rankedTools.map((tool, index) => (
            <article class="ranking-row">
              <span class="rank-number">#{index + 1}</span>
              <div>
                <h3><a href={localizedPath(lang, `/tools/${tool.slug}`)}>{tool.name[lang]}</a></h3>
                <p>{tool.tagline[lang]}</p>
              </div>
              <a class="button secondary" href={localizedPath(lang, `/tools/${tool.slug}`)}>{t(lang, "view")}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
