---
import CategoryCard from "@/components/CategoryCard.astro";
import PlatformCard from "@/components/PlatformCard.astro";
import AccountCard from "@/components/AccountCard.astro";
import BusinessCTA from "@/components/BusinessCTA.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatNumber, getCategories, getCategoryCounts, getFeaturedAccounts, getLatestAccounts, getRankedAccounts, getPlatforms, getNews, getGuides } from "@/lib/directory";
import { languages, localizedPath, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const [featuredAccounts, latestAccounts, rankedAccounts, categories, platforms] = await Promise.all([
  getFeaturedAccounts(),
  getLatestAccounts(),
  getRankedAccounts("followers"),
  getCategories(),
  getPlatforms()
]);
const categoryCounts = await getCategoryCounts();

const quickLinks = [
  { label: t(lang, "quickHot"), href: localizedPath(lang, "/rankings") },
  { label: t(lang, "quickGrowing"), href: localizedPath(lang, "/rankings") },
  { label: t(lang, "quickNew"), href: localizedPath(lang, "/new") },
  { label: t(lang, "quickDouyin"), href: localizedPath(lang, "/platforms/douyin") },
  { label: t(lang, "quickXiaohongshu"), href: localizedPath(lang, "/platforms/xiaohongshu") },
  { label: t(lang, "quickBilibili"), href: localizedPath(lang, "/platforms/bilibili") },
  { label: t(lang, "quickYoutube"), href: localizedPath(lang, "/platforms/youtube") },
  { label: t(lang, "quickAiCreators"), href: localizedPath(lang, "/categories/ai-content") }
];

const news = await getNews(lang);
const guides = await getGuides(lang);
---

<BaseLayout lang={lang} title={`${t(lang, "brand")} - ${t(lang, "slogan")}`} description={t(lang, "heroSubtitle")}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">🌅 {t(lang, "dailyUpdated")}</p>
        <h1>{t(lang, "heroTitle")}</h1>
        <p class="lead">{t(lang, "heroSubtitle")}</p>
        <form class="search-panel" action={localizedPath(lang, "/accounts")} method="get">
          <input name="q" type="search" placeholder={t(lang, "searchPlaceholder")} />
          <button class="button" type="submit">{t(lang, "search")}</button>
        </form>
      </div>
      <aside class="stats-card" aria-label="Directory stats">
        <div class="stat">
          <strong>{latestAccounts.length}</strong>
          <span>{t(lang, "statAccounts")}</span>
        </div>
        <div class="stat">
          <strong>{platforms.length}</strong>
          <span>{t(lang, "statPlatforms")}</span>
        </div>
        <div class="stat">
          <strong>{categories.length}</strong>
          <span>{t(lang, "statNiches")}</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="quick-section">
    <div class="container quick-links">
      {quickLinks.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
  </section>

  <section class="section">
    <div class="container directory-layout">
      <div>
        <div class="section-head compact">
          <h2>{t(lang, "today")}</h2>
          <a class="button secondary" href={localizedPath(lang, "/new")}>{t(lang, "more")}</a>
        </div>
        <div class="feed-list">
          {
            latestAccounts.map((account, index) => (
              <>
                {index === 2 && (
                  <BusinessCTA lang={lang} type="home-flow" />
                )}
                <article class="feed-row">
                  <span class="account-logo">{account.avatar}</span>
                  <div>
                    <h3>
                      <a href={localizedPath(lang, `/accounts/${account.slug}`)}>{account.name[lang]}</a>
                      {account.verified && <span class="verified-badge" style="color: #6366f1; margin-left: 6px;">✓</span>}
                    </h3>
                    <p>{account.description[lang]}</p>
                    <div class="tag-row">
                      <span class="pill">{account.platformItem?.name[lang] || account.platform}</span>
                      {account.tags.slice(0, 4).map((tag) => <span class="pill">#{tag}</span>)}
                    </div>
                  </div>
                  <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 8px;">
                    <span style="font-size: 0.85rem; color: #64748b;">{formatNumber(account.followerCount, lang)} {t(lang, "followers")}</span>
                    <a class="button secondary" href={localizedPath(lang, `/accounts/${account.slug}`)}>{t(lang, "view")}</a>
                  </div>
                </article>
              </>
            ))
          }
        </div>
      </div>
      <aside class="side-rail">
        <div class="rail-panel">
          <h2>{t(lang, "rankings")}</h2>
          <div class="mini-list">
            {
              rankedAccounts.slice(0, 5).map((account, index) => (
                <a href={localizedPath(lang, `/accounts/${account.slug}`)}>
                  <strong>#{index + 1}</strong>
                  <span>{account.name[lang]}</span>
                  <small>{formatNumber(account.followerCount, lang)}</small>
                </a>
              ))
            }
          </div>
        </div>
        <div class="rail-panel">
          <h2>{t(lang, "navServices")}</h2>
          <div style="font-size: 0.9rem; color: #475569; display: flex; flex-direction: column; gap: 12px;">
            <p>{t(lang, "servicesSubtitle")}</p>
            <a class="button primary full-width text-center" href={localizedPath(lang, "/services")}>
              {t(lang, "servicesCTA")}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "platformNav")}</h2>
      </div>
      <div class="category-grid">
        {platforms.slice(0, 6).map((platform) => <PlatformCard platform={platform as any} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "categories")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/categories")}>{t(lang, "more")}</a>
      </div>
      <div class="category-grid">
        {categories.slice(0, 6).map((category) => <CategoryCard category={category} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t(lang, "featured")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/accounts")}>{t(lang, "allAccounts")}</a>
      </div>
      <div class="grid">
        {featuredAccounts.map((account) => <AccountCard account={account} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container seo-grid">
      <section class="seo-panel">
        <div class="section-head compact">
          <h2>{t(lang, "news")}</h2>
        </div>
        <ol class="link-list">
          {news.map((item) => <li><a href={localizedPath(lang, item.url)}>{item.title}</a></li>)}
        </ol>
      </section>
      <section class="seo-panel">
        <div class="section-head compact">
          <h2>{t(lang, "guides")}</h2>
        </div>
        <ol class="link-list">
          {guides.map((item) => <li><a href={localizedPath(lang, item.url)}>{item.title}</a></li>)}
        </ol>
      </section>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head compact">
        <h2>{t(lang, "freeCategories")}</h2>
        <a class="button secondary" href={localizedPath(lang, "/categories")}>{t(lang, "more")}</a>
      </div>
      <div class="category-index">
        {
          categoryCounts.map(({ category, count }) => (
            <a href={localizedPath(lang, `/categories/${category.slug}`)}>
              <span>{category.name[lang]}</span>
              <strong>{count} {lang === "zh" ? "个账号" : "creators"}</strong>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
