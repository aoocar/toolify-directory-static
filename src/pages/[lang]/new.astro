---
import ToolCard from "@/components/ToolCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLatestTools } from "@/lib/directory";
import { languages, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tools = await getLatestTools();
---

<BaseLayout lang={lang} title={`${t(lang, "latest")} - ${t(lang, "brand")}`} description={t(lang, "heroSubtitle")}>
  <section class="page-title">
    <div class="container">
      <h1>{t(lang, "latest")}</h1>
      <p class="lead">{t(lang, "heroSubtitle")}</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid">
      {tools.map((tool) => <ToolCard tool={tool} lang={lang} />)}
    </div>
  </section>
</BaseLayout>
