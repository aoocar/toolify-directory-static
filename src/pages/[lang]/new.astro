---
import AccountCard from "@/components/AccountCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLatestAccounts } from "@/lib/directory";
import { languages, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const latestAccounts = await getLatestAccounts();
---

<BaseLayout lang={lang} title={`${t(lang, "navNew")} - ${t(lang, "brand")}`} description={t(lang, "heroSubtitle")}>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h1>{t(lang, "navNew")}</h1>
      </div>
      <div class="grid">
        {latestAccounts.map((account) => <AccountCard account={account} lang={lang} />)}
      </div>
    </div>
  </section>
</BaseLayout>
