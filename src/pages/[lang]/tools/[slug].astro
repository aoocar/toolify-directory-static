---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatNumber, getTools, getToolBySlug } from "@/lib/directory";
import { languages, localizedPath, t, type Lang } from "@/lib/i18n";

export async function getStaticPaths() {
  const tools = await getTools();
  return languages.flatMap((lang) =>
    tools.map((tool) => ({ params: { lang, slug: tool.slug } }))
  );
}

const lang = Astro.params.lang as Lang;
const tool = await getToolBySlug(Astro.params.slug ?? "");

if (!tool) {
  return Astro.redirect(localizedPath(lang, "/tools"));
}
---

<BaseLayout lang={lang} title={`${tool.name[lang]} - ${t(lang, "brand")}`} description={tool.tagline[lang]}>
  <section class="page-title">
    <div class="container">
      <h1>{tool.name[lang]}</h1>
      <p class="lead">{tool.tagline[lang]}</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <article class="detail-panel">
        <div class="detail-header">
          <div class="tool-card-head">
            <span class="tool-logo">{tool.logo}</span>
            <div>
              <h2>{tool.name[lang]}</h2>
              <div class="meta-row">
                <span class="pill">{tool.pricing}</span>
                <span class="pill">{formatNumber(tool.monthlyVisits, lang)} {t(lang, "visits")}</span>
                <span class="pill">{formatNumber(tool.savedCount, lang)} {t(lang, "saves")}</span>
              </div>
            </div>
          </div>
          <a class="button" href={tool.website} target="_blank" rel="noreferrer">{t(lang, "visitWebsite")}</a>
        </div>
        <p class="lead">{tool.description[lang]}</p>
        <h3>{t(lang, "categories")}</h3>
        <div class="tag-row">
          {
            tool.categoryItems.map((category) => (
              <a class="pill" href={localizedPath(lang, `/categories/${category.slug}`)}>
                {category.name[lang]}
              </a>
            ))
          }
        </div>
        <h3>{t(lang, "tags")}</h3>
        <div class="tag-row">
          {tool.tags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
