---
import ToolCard from "@/components/ToolCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTools } from "@/lib/directory";
import { languages, t, type Lang } from "@/lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const tools = await getTools();
const query = Astro.url.searchParams.get("q")?.toLowerCase() ?? "";
const visibleTools = query
  ? tools.filter((tool) =>
      [tool.name[lang], tool.tagline[lang], tool.description[lang], ...tool.tags]
        .join(" ")
        .toLowerCase()
        .includes(query)
    )
  : tools;
---

<BaseLayout lang={lang} title={`${t(lang, "allTools")} - ${t(lang, "brand")}`} description={t(lang, "heroSubtitle")}>
  <section class="page-title">
    <div class="container">
      <h1>{t(lang, "allTools")}</h1>
      <p class="lead">{t(lang, "heroSubtitle")}</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid">
        {visibleTools.map((tool) => <ToolCard tool={tool} lang={lang} />)}
      </div>
      {visibleTools.length === 0 && <p>{t(lang, "empty")}</p>}
    </div>
  </section>
</BaseLayout>
